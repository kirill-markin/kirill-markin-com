{
  "name": "website-next-js",
  "version": "0.1.0",
  "private": true,
  "description": "Source code for kirill-markin.com website built with Next.js, migrated from Jekyll for improved performance and developer experience",
  "author": "Kirill Markin",
  "license": "MIT",
  "scripts": {
    "dev": "eslint . && next dev  --turbopack",
    "build": "npm run generate-public-data && next build",
    "start": "next start",
    "lint": "eslint .",
    "analyze": "npm run generate-public-data && ANALYZE=true next build",
    "vercel-build": "npm run generate-public-data && next build",
    "validate-metadata": "tsx scripts/validate-metadata.ts",
    "generate-public-data": "npm run generate-weight-data && npm run generate-genome-public-data",
    "generate-weight-data": "tsx scripts/generate-weight-data.ts",
    "generate-genome-public-data": "tsx scripts/generate-genome-public-data.ts",
    "test-cache": "tsx scripts/test-cache-headers.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.60.0",
    "@tailwindcss/typography": "^0.5.20",
    "@vercel/speed-insights": "^2.0.0",
    "d3": "^7.9.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-rehype": "^11.1.2",
    "unist-util-visit": "^5.1.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.5.1",
    "chalk": "^5.6.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kirill-markin/website-next-js"
  },
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "static-site",
    "personal-website",
    "kirill-markin",
    "ozma",
    "data-engineering"
  ],
  "packageManager": "npm@11.17.0"
}
